# Python cache/build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/

# Virtual environments / local tooling
.venv/
venv/
.env
.env.*
.vscode/

# OS/editor noise
.DS_Store
Thumbs.db
*.tmp
*.log

# Local debug files
live_console_err.txt

# Dataset source media (do not push)
data/raw/

# Runtime-transient processed outputs (keep ignored)
data/processed/audio_raw/
data/processed/logs/

# If models are large and downloaded locally, keep ignored
# (remove this if you want to version these model files)
data/models/

# Large media / generated outputs
*.wav
*.mp3
*.mp4
*.avi
*.mov
*.mkv
*.jsonl

# Keep required processed dataset artifacts versioned
!data/processed/manifests/*.jsonl
!data/processed/manifests/*.json
!data/processed/pose/**/*.json
!data/processed/models/**
!data/processed/timelines/**/*.json

# Optional: Whisper/faster-whisper local cache (outside repo usually)
.faster-whisper/
.cache/

# Dependencies
node_modules
.pnpm-store

# Next.js build output
.next
out
.turbo

# Production build artifacts
build

# Environment variables
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Testing / coverage
coverage
*.lcov

# TypeScript
*.tsbuildinfo

# Tooling / editor
.vercel
.idea
